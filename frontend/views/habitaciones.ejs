<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Habitaciones | Peludópolis</title>

  <link rel="stylesheet" href="/styles/main.css">
  <link rel="stylesheet" href="/styles/habitaciones.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">Peludópolis</a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link active" href="/habitaciones">Habitaciones</a></li>
          <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
          <li class="nav-item"><a class="nav-link" href="/reviews">Reseñas</a></li>
        </ul>

        <div id="nav-guest">
          <a href="/" class="text-white text-decoration-none" aria-label="Cuenta">
            <i class="bi bi-person-circle fs-4"></i>
          </a>
        </div>

        <div id="nav-user" style="display: none;">
          <div class="dropdown">
            <a role="button"
               class="text-white text-decoration-none dropdown-toggle d-flex align-items-center gap-2"
               data-bs-toggle="dropdown"
               aria-expanded="false">
              <i class="bi bi-person-circle fs-4"></i>
              <span id="navUserName">Usuario</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/me">Mi Perfil</a></li>
              <li><a class="dropdown-item" href="/pets">Mis Mascotas</a></li>
              <li><a class="dropdown-item" href="/reservations">Mis Reservaciones</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><button class="dropdown-item" type="button" id="logoutButton">Cerrar Sesión</button></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section class="text-center mb-4">
      <h1 class="fw-bold">Habitaciones</h1>
      <p class="text-muted mb-0">
        Consulta las habitaciones disponibles para tu mascota.
      </p>
    </section>

    <section class="card shadow-sm border-0 mb-4">
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Tipo de mascota</label>
            <select id="speciesFilter" class="form-select">
              <option value="">Todas</option>
              <option value="perro">Perro</option>
              <option value="gato">Gato</option>
              <option value="reptil">Reptil</option>
              <option value="ambos">Perro/Gato</option>
            </select>
          </div>

          <div class="col-md-4">
            <label class="form-label">Tamaño</label>
            <select id="sizeFilter" class="form-select">
              <option value="">Todos</option>
              <option value="pequeno">Pequeño</option>
              <option value="mediano">Mediano</option>
              <option value="grande">Grande</option>
              <option value="todos">Todos</option>
            </select>
          </div>

          <div class="col-md-4">
            <label class="form-label">Precio máximo</label>
            <input id="maxPriceFilter" type="number" class="form-control" placeholder="Ej. 800">
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
          <small id="roomsCounter" class="text-muted">Cargando habitaciones...</small>
          <button id="clearFiltersBtn" type="button" class="btn btn-outline-secondary btn-sm">
            Limpiar filtros
          </button>
        </div>
      </div>
    </section>

    <div id="roomsAlert" class="alert d-none" role="alert"></div>

    <section id="roomsGrid" class="row g-4"></section>
  </main>

  <script>
    const API_BASE_URL = "http://localhost:3000";

    const roomsGrid = document.getElementById("roomsGrid");
    const roomsAlert = document.getElementById("roomsAlert");
    const roomsCounter = document.getElementById("roomsCounter");

    const speciesFilter = document.getElementById("speciesFilter");
    const sizeFilter = document.getElementById("sizeFilter");
    const maxPriceFilter = document.getElementById("maxPriceFilter");
    const clearFiltersBtn = document.getElementById("clearFiltersBtn");

    let rooms = [];

    const resolveImageUrl = (imageUrl) => {
      if (!imageUrl) return "/assets/Habitaciones.jpg";

      if (
        imageUrl.startsWith("http://") ||
        imageUrl.startsWith("https://") ||
        imageUrl.startsWith("data:")
      ) {
        return imageUrl;
      }

      if (imageUrl.startsWith("/assets/")) {
        return imageUrl;
      }

      const normalized = imageUrl
        .replaceAll("\\", "/")
        .replace(/^(\.\/|\.\.\/)+/, "")
        .replace(/^frontend\/views\//, "")
        .replace(/^frontend\/src\//, "")
        .replace(/^views\//, "")
        .replace(/^src\//, "")
        .replace(/^assets\//, "");

      const filename = normalized.split("/").pop();

      return `/assets/${filename}`;
    };

    const normalizeRoom = (room) => ({
      id: room.id || room.room_id,
      name: room.name || room.room_name || room.nombre_habitacion || "Habitación",
      petType: room.pet_type_allowed || room.tipo_mascota_permitida || room.type || "",
      size: room.size_allowed || room.tamaño_permitido || room.tamano_permitido || room.size || "",
      price: Number(room.price_per_night || room.precio_noche || room.price || 0),
      description: room.description || room.descripcion || "Sin descripción disponible.",
      status: room.status || room.estado || "disponible",
      capacity: room.capacity || room.capacidad || 1,
      imageUrl: resolveImageUrl(room.image_url || room.imagen_url)
    });

    const showAlert = (type, message) => {
      roomsAlert.className = `alert alert-${type}`;
      roomsAlert.textContent = message;
    };

    const hideAlert = () => {
      roomsAlert.className = "alert d-none";
      roomsAlert.textContent = "";
    };

    const formatMoney = (value) => {
      return new Intl.NumberFormat("es-MX", {
        style: "currency",
        currency: "MXN"
      }).format(value);
    };

    const renderRooms = () => {
      hideAlert();

      const species = speciesFilter.value;
      const size = sizeFilter.value;
      const maxPrice = Number(maxPriceFilter.value || 0);

      const filteredRooms = rooms.filter((room) => {
        const matchesSpecies = !species || room.petType === species || room.petType === "ambos";
        const matchesSize = !size || room.size === size || room.size === "todos";
        const matchesPrice = !maxPrice || room.price <= maxPrice;

        return matchesSpecies && matchesSize && matchesPrice;
      });

      roomsCounter.textContent = `${filteredRooms.length} habitación(es) encontrada(s)`;

      if (!filteredRooms.length) {
        roomsGrid.innerHTML = `
          <div class="col-12">
            <div class="text-center py-5 border rounded bg-light">
              <i class="bi bi-house-heart fs-1 text-muted"></i>
              <h5 class="mt-3">No hay habitaciones para estos filtros</h5>
              <p class="text-muted mb-0">Prueba cambiando los criterios de búsqueda.</p>
            </div>
          </div>
        `;
        return;
      }

      roomsGrid.innerHTML = filteredRooms.map((room) => {
        const statusClass = room.status === "disponible" ? "bg-success" : "bg-secondary";

        return `
          <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm room-hover">
              <div class="position-relative">
                <img src="${room.imageUrl}" class="card-img-top hab_img" alt="${room.name}">
                <span class="badge ${statusClass} position-absolute top-0 end-0 m-2">${room.status}</span>
              </div>

              <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                  <h5 class="card-title mb-0">${room.name}</h5>
                  <span class="badge bg-primary">${room.petType || "N/A"}</span>
                </div>

                <p class="card-text flex-grow-1">${room.description}</p>

                <div class="d-flex flex-wrap gap-2 mb-3">
                  <span class="badge bg-light text-dark border">
                    <i class="bi bi-rulers"></i> ${room.size || "N/A"}
                  </span>
                  <span class="badge bg-light text-dark border">
                    <i class="bi bi-people"></i> Capacidad ${room.capacity}
                  </span>
                </div>

                <p class="fw-bold mt-auto mb-3" style="color:#4f737f;">
                  ${formatMoney(room.price)} / noche
                </p>

                <a href="/habitacion?id=${room.id}" class="btn btn-outline-primary">
                  Ver detalle
                </a>
              </div>
            </div>
          </div>
        `;
      }).join("");
    };

    const loadRooms = async () => {
      try {
        roomsGrid.innerHTML = `
          <div class="col-12 text-center py-5">
            <div class="spinner-border" role="status"></div>
            <p class="text-muted mt-3">Cargando habitaciones...</p>
          </div>
        `;

        const response = await fetch(`${API_BASE_URL}/rooms`);
        const payload = await response.json();

        if (!response.ok || payload.ok === false) {
          throw new Error(payload.message || "No se pudieron cargar las habitaciones");
        }

        const rawRooms = Array.isArray(payload.data) ? payload.data : payload;
        rooms = rawRooms.map(normalizeRoom);

        renderRooms();
      } catch (error) {
        roomsCounter.textContent = "No se pudieron cargar habitaciones";
        roomsGrid.innerHTML = "";
        showAlert("danger", `${error.message}. Revisa que el backend tenga GET /rooms público.`);
      }
    };

    [speciesFilter, sizeFilter, maxPriceFilter].forEach((input) => {
      input.addEventListener("input", renderRooms);
      input.addEventListener("change", renderRooms);
    });

    clearFiltersBtn.addEventListener("click", () => {
      speciesFilter.value = "";
      sizeFilter.value = "";
      maxPriceFilter.value = "";
      renderRooms();
    });

    loadRooms();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/api/auth.api.js"></script>
</body>
</html>