<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - Peludópolis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/profiles.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light nbprofile">
        <div class="container">
            <a class="navbar-brand" href="/">Peludópolis</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/me">Mi Perfil</a>
                <a class="nav-link" href="/reservations">Reservaciones</a>
                <button class="btn btn-outline-danger btn-sm ms-lg-2" type="button" id="logoutButton">
                    Cerrar sesión
                </button>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div id="profile-content">
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p>Cargando perfil...</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function loadProfile() {
            const token = localStorage.getItem('peludopolis_token');
            if (!token) {
                document.getElementById('profile-content').innerHTML = `
                    <div class="alert alert-warning text-center">
                        <h3>No estás autenticado</h3>
                        <p>Por favor, inicia sesión para ver tu perfil.</p>
                        <a href="/" class="btn btn-primary">Volver al inicio</a>
                    </div>
                `;
                return;
            }

            try {
                const response = await fetch('http://localhost:3000/auth/me', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    }
                });
                const data = await response.json();

                if (data.ok) {
                    displayProfile(data.data);
                } else {
                    document.getElementById('profile-content').innerHTML = `
                        <div class="alert alert-danger">
                            <h3>Error al cargar perfil</h3>
                            <p>${data.message || 'Token inválido'}</p>
                        </div>
                    `;
                }
            } catch (error) {
                document.getElementById('profile-content').innerHTML = `
                    <div class="alert alert-danger">
                        <h3>Error de conexión</h3>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        function displayProfile(user) {
            document.getElementById('profile-content').innerHTML = `
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h2 class="mb-0">Mi Perfil</h2>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h5><strong>Información personal</strong></h5>
                                        <p><strong>Usuario:</strong> ${user.username}</p>
                                        <p><strong>Email:</strong> ${user.email}</p>
                                        <p><strong>Nombre:</strong> ${user.firstName || 'No especificado'}</p>
                                        <p><strong>Apellido:</strong> ${user.lastName || 'No especificado'}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <h5><strong>Datos adicionales</strong></h5>
                                        <p><strong>Teléfono:</strong> ${user.phone || 'No especificado'}</p>
                                        <p><strong>Dirección:</strong> ${user.address || 'No especificado'}</p>
                                        <p><strong>Rol:</strong> ${user.role}</p>
                                        <p><strong>Estado:</strong> ${user.status}</p>
                                    </div>
                                </div>
                                <div class="mt-4 d-flex flex-column flex-md-row gap-2">
                                    <a href="/profile/edit" class="btn btn-primary">Editar perfil</a>
                                    <a href="/pets" class="btn btn-outline-secondary">Ver mascotas</a>
                                    <a href="/reservations" class="btn btn-outline-secondary">Ver reservaciones</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        loadProfile();
    </script>
    <script src="/api/auth.api.js"></script>
</body>
</html>
