<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - Peludópolis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand" href="/">Peludópolis</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/profile">Perfil</a>
                <a class="nav-link" href="/pets">Mascotas</a>
                <a class="nav-link" href="/reservations">Reservaciones</a>
                <button class="btn btn-outline-danger btn-sm ms-lg-2" type="button" id="logoutButton">
                    Cerrar sesión
                </button>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div id="profile-content">
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p>Cargando perfil...</p>
            </div>
        </div>
    </div>

    <script src="/config.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function loadProfile() {
            const token = localStorage.getItem('peludopolis_token');
            if (!token) {
                window.location.href = '/';
                return;
            }

            try {
                const response = await fetch(`${API_BASE_URL}/users/me`, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    }
                });

                const data = await response.json();

                if (data.ok) {
                    displayProfile(data.data);
                } else {
                    document.getElementById('profile-content').innerHTML = `
                        <div class="alert alert-danger">
                            Error al cargar el perfil: ${data.message}
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('profile-content').innerHTML = `
                    <div class="alert alert-danger">
                        Error de conexión. Inténtalo de nuevo.
                    </div>
                `;
            }
        }

        function displayProfile(user) {
            document.getElementById('profile-content').innerHTML = `
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card">
                            <div class="card-header">
                                <h2>Mi Perfil</h2>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h5>Información Personal</h5>
                                        <p><strong>Nombre de usuario:</strong> ${user.username}</p>
                                        <p><strong>Email:</strong> ${user.email}</p>
                                        <p><strong>Nombre:</strong> ${user.firstName || 'No especificado'}</p>
                                        <p><strong>Apellido:</strong> ${user.lastName || 'No especificado'}</p>
                                        <p><strong>Teléfono:</strong> ${user.phone || 'No especificado'}</p>
                                        <p><strong>Dirección:</strong> ${user.address || 'No especificado'}</p>
                                        <p><strong>Rol:</strong> ${user.role}</p>
                                        <p><strong>Estado:</strong> ${user.status}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <h5>Acciones</h5>
                                        <a href="/profile/edit" class="btn btn-primary mb-2">Editar Perfil</a>
                                        <br>
                                        <a href="/pets" class="btn btn-secondary mb-2">Ver Mascotas</a>
                                        <br>
                                        <a href="/reservations" class="btn btn-secondary">Ver Reservaciones</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Load profile when page loads
        loadProfile();
    </script>
    <script src="/api/auth.api.js"></script>
</body>
</html>