<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Servicios - Peludópolis</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/styles/main.css">
  <style>
    .page-hero {
      background: linear-gradient(135deg, #4c4163, #717f4f);
      color: white;
      border-radius: 24px;
      padding: 3rem 2rem;
    }

    .service-card {
      border: 0;
      border-radius: 20px;
      overflow: hidden;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12);
    }

    .service-icon {
      width: 56px;
      height: 56px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #e1d6eb;
      color: #4c4163;
      font-size: 1.6rem;
    }

    .price-pill {
      background: #717f4f;
      color: white;
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      font-weight: 700;
    }

    .empty-state {
      border: 2px dashed #d7d0df;
      border-radius: 20px;
      padding: 3rem 1rem;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-house-heart"></i> Peludópolis
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu"
        aria-controls="navMenu" aria-expanded="false" aria-label="Abrir menú">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="/habitaciones">Habitaciones</a></li>
          <li class="nav-item"><a class="nav-link active" href="/servicios">Servicios</a></li>
          <li class="nav-item"><a class="nav-link" href="/reviews">Reseñas</a></li>
        </ul>

        <div class="d-flex gap-3 align-items-center" id="nav-auth">
          <div id="nav-guest">
            <a role="button" class="text-white text-decoration-none" href="/" aria-label="Cuenta">
              <i class="bi bi-person-circle fs-4"></i>
            </a>
          </div>

          <div id="nav-user" style="display: none;">
            <div class="dropdown">
              <a role="button"
                style="cursor: pointer;"
                class="text-white text-decoration-none dropdown-toggle d-flex align-items-center gap-2"
                data-bs-toggle="dropdown"
                aria-expanded="false">
                <i class="bi bi-person-circle fs-4"></i>
                <span id="navUserName">Usuario</span>
              </a>

              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/me">Mi Perfil</a></li>
                <li><a class="dropdown-item" href="/pets">Mis Mascotas</a></li>
                <li><a class="dropdown-item" href="/reservations">Mis Reservaciones</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><button class="dropdown-item" type="button" id="logoutButton">Cerrar Sesión</button></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="container my-5">
    <section class="page-hero mb-5 shadow-sm">
      <div class="row align-items-center gy-4">
        <div class="col-lg-8">
          <span class="badge rounded-pill text-bg-light mb-3">Cuidados extra</span>
          <h1 class="display-6 fw-bold mb-3">Servicios adicionales para consentir a tu mascota</h1>
          <p class="lead mb-0">
            Agrega baños, higiene y actividades extra a la reservación de tu peludo.
          </p>
        </div>
        <div class="col-lg-4 text-lg-end">
          <i class="bi bi-stars" style="font-size: 6rem; opacity: .85;"></i>
        </div>
      </div>
    </section>

    <section class="row g-3 mb-4 align-items-end">
      <div class="col-md-6 col-lg-4">
        <label for="serviceSearch" class="form-label fw-semibold">Buscar servicio</label>
        <input id="serviceSearch" type="search" class="form-control" placeholder="Baño, uñas, paseo...">
      </div>

      <div class="col-md-6 col-lg-4">
        <label for="serviceTypeFilter" class="form-label fw-semibold">Tipo de servicio</label>
        <select id="serviceTypeFilter" class="form-select">
          <option value="all">Todos</option>
        </select>
      </div>

      <div class="col-lg-4 text-lg-end">
        <span class="text-muted"><span id="serviceCount">0</span> servicios disponibles</span>
      </div>
    </section>

    <div id="servicesAlert" class="alert d-none" role="alert"></div>

    <section id="servicesLoading" class="text-center py-5">
      <div class="spinner-border" role="status"></div>
      <p class="mt-3 text-muted">Cargando servicios...</p>
    </section>

    <section id="servicesGrid" class="row g-4 d-none"></section>

    <section id="emptyState" class="empty-state text-center d-none">
      <i class="bi bi-search fs-1 text-muted"></i>
      <h3 class="mt-3">No encontramos servicios</h3>
      <p class="text-muted mb-0">Prueba cambiando el filtro o la búsqueda.</p>
    </section>
  </main>

  <footer class="py-4 mt-5" style="background:#4c4163;color:white;">
    <div class="container text-center">
      <p class="mb-0">© 2026 Peludópolis - Todos los derechos reservados</p>
    </div>
  </footer>

  <script src="/config.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const API_BASE_URL = window.PELUDOPOLIS_API_URL || "http://localhost:3000";
    const TOKEN_KEY = "peludopolis_token";
    const USER_KEY = "peludopolis_user";

    let services = [];

    const formatCurrency = (value) => {
      const numberValue = Number(value || 0);
      return new Intl.NumberFormat("es-MX", {
        style: "currency",
        currency: "MXN"
      }).format(numberValue);
    };

    const normalize = (value) => String(value || "").toLowerCase().trim();

    const getServiceIcon = (serviceType) => {
      const type = normalize(serviceType);

      if (type.includes("higiene")) return "bi-droplet";
      if (type.includes("actividad")) return "bi-person-walking";
      if (type.includes("salud")) return "bi-heart-pulse";
      if (type.includes("estetica") || type.includes("estética")) return "bi-scissors";

      return "bi-stars";
    };

    const showAlert = (message, type = "danger") => {
      const alert = document.getElementById("servicesAlert");
      alert.className = `alert alert-${type}`;
      alert.textContent = message;
    };

    const hideAlert = () => {
      const alert = document.getElementById("servicesAlert");
      alert.className = "alert d-none";
      alert.textContent = "";
    };

    const getStoredUser = () => {
      try {
        return JSON.parse(localStorage.getItem(USER_KEY) || "null");
      } catch {
        return null;
      }
    };

    const updateNavbar = () => {
      const user = getStoredUser();
      const navGuest = document.getElementById("nav-guest");
      const navUser = document.getElementById("nav-user");
      const navUserName = document.getElementById("navUserName");

      if (!navGuest || !navUser) return;

      if (user) {
        navGuest.style.display = "none";
        navUser.style.display = "block";
        if (navUserName) navUserName.textContent = user.firstName || user.username || "Usuario";
        return;
      }

      navGuest.style.display = "block";
      navUser.style.display = "none";
    };

    const logout = () => {
      localStorage.removeItem(TOKEN_KEY);
      localStorage.removeItem(USER_KEY);
      window.location.href = "/";
    };

    const renderTypeOptions = () => {
      const select = document.getElementById("serviceTypeFilter");
      const types = [...new Set(services.map(service => service.service_type).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, "es"));

      select.innerHTML = '<option value="all">Todos</option>';

      types.forEach((type) => {
        const option = document.createElement("option");
        option.value = type;
        option.textContent = type.charAt(0).toUpperCase() + type.slice(1);
        select.appendChild(option);
      });
    };

    const getFilteredServices = () => {
      const search = normalize(document.getElementById("serviceSearch").value);
      const type = document.getElementById("serviceTypeFilter").value;

      return services.filter((service) => {
        const matchesSearch = !search ||
          normalize(service.name).includes(search) ||
          normalize(service.description).includes(search) ||
          normalize(service.service_type).includes(search);

        const matchesType = type === "all" || service.service_type === type;

        return matchesSearch && matchesType;
      });
    };

    const renderServices = () => {
      const grid = document.getElementById("servicesGrid");
      const emptyState = document.getElementById("emptyState");
      const count = document.getElementById("serviceCount");
      const filteredServices = getFilteredServices();

      count.textContent = filteredServices.length;

      if (!filteredServices.length) {
        grid.classList.add("d-none");
        emptyState.classList.remove("d-none");
        grid.innerHTML = "";
        return;
      }

      emptyState.classList.add("d-none");
      grid.classList.remove("d-none");

      grid.innerHTML = filteredServices.map((service) => `
        <div class="col-md-6 col-xl-4">
          <article class="card service-card h-100 shadow-sm">
            <div class="card-body p-4 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <span class="service-icon">
                  <i class="bi ${getServiceIcon(service.service_type)}"></i>
                </span>
                <span class="price-pill">${formatCurrency(service.price)}</span>
              </div>

              <h3 class="h5 fw-bold mb-2">${service.name}</h3>
              <p class="text-muted flex-grow-1">${service.description || "Servicio adicional para tu mascota."}</p>

              <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="badge rounded-pill text-bg-light border">
                  ${service.service_type || "general"}
                </span>
                <small class="text-muted">ID ${service.id}</small>
              </div>
            </div>
          </article>
        </div>
      `).join("");
    };

    const loadServices = async () => {
      const loading = document.getElementById("servicesLoading");
      const grid = document.getElementById("servicesGrid");
      const emptyState = document.getElementById("emptyState");

      loading.classList.remove("d-none");
      grid.classList.add("d-none");
      emptyState.classList.add("d-none");
      hideAlert();

      try {
        const response = await fetch(`${API_BASE_URL}/services`);
        const body = await response.json();

        if (!response.ok || body.ok === false) {
          throw new Error(body.message || "No se pudieron cargar los servicios.");
        }

        services = Array.isArray(body.data) ? body.data : [];
        renderTypeOptions();
        renderServices();
      } catch (error) {
        services = [];
        renderServices();
        showAlert(`${error.message} Revisa que el backend tenga activo GET /services.`);
      } finally {
        loading.classList.add("d-none");
      }
    };

    document.addEventListener("DOMContentLoaded", () => {
      updateNavbar();
      loadServices();

      document.getElementById("logoutButton")?.addEventListener("click", logout);
      document.getElementById("serviceSearch")?.addEventListener("input", renderServices);
      document.getElementById("serviceTypeFilter")?.addEventListener("change", renderServices);
    });
  </script>
</body>
</html>
