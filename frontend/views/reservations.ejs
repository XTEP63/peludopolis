<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis Reservaciones - Peludópolis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/styles/main.css">
  <style>
    :root {
      --peludo-primary: #4c4163;
      --peludo-soft: #f7f4fb;
      --peludo-border: #e6dff0;
    }

    body {
      background: var(--peludo-soft);
      min-height: 100vh;
    }

    .navbar {
      background: var(--peludo-primary) !important;
    }

    .navbar .navbar-brand,
    .navbar .nav-link {
      color: #fff !important;
    }

    .page-header,
    .stat-card,
    .reservation-card,
    .empty-state,
    .soft-card {
      background: #fff;
      border: 1px solid var(--peludo-border);
      border-radius: 20px;
      box-shadow: 0 10px 24px rgba(76, 65, 99, 0.07);
    }

    .page-header {
      border-radius: 22px;
      padding: 28px;
      box-shadow: 0 12px 30px rgba(76, 65, 99, 0.08);
    }

    .stat-card {
      padding: 20px;
    }

    .stat-card .value {
      font-size: 1.7rem;
      font-weight: 800;
      color: var(--peludo-primary);
    }

    .reservation-card {
      padding: 22px;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .reservation-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px rgba(76, 65, 99, 0.11);
    }

    .badge-status {
      border-radius: 999px;
      padding: 8px 12px;
      font-weight: 700;
      text-transform: capitalize;
      display: inline-block;
    }

    .badge-pendiente { background: #fff3cd; color: #856404; }
    .badge-confirmada { background: #d1e7dd; color: #0f5132; }
    .badge-en_curso { background: #cff4fc; color: #055160; }
    .badge-finalizada { background: #e2e3e5; color: #41464b; }
    .badge-cancelada { background: #f8d7da; color: #842029; }
    .badge-pagado { background: #d1e7dd; color: #0f5132; }
    .badge-sin_pago { background: #fff3cd; color: #856404; }

    .btn-peludo {
      background: var(--peludo-primary);
      color: #fff;
      border: none;
    }

    .btn-peludo:hover {
      background: #3c334f;
      color: #fff;
    }

    .muted-label {
      color: #6c6578;
      font-size: 0.9rem;
      margin-bottom: 4px;
    }

    .amount {
      color: var(--peludo-primary);
      font-weight: 800;
    }

    .detail-section {
      border: 1px solid var(--peludo-border);
      border-radius: 16px;
      padding: 16px;
      background: #fff;
      margin-bottom: 14px;
    }

    .loading-shell {
      min-height: 220px;
      display: grid;
      place-items: center;
    }

    .room-option-card,
    .pet-option-card,
    .service-option-card {
      border: 1px solid var(--peludo-border);
      border-radius: 16px;
      padding: 14px;
      background: #fff;
    }

    .service-row {
      border: 1px solid var(--peludo-border);
      border-radius: 14px;
      padding: 12px;
    }
    #createReservationModal .modal-dialog {
      max-height: calc(100dvh - 1rem);
      margin-top: 0.5rem;
      margin-bottom: 0.5rem;
    }

    #createReservationModal .modal-content {
      max-height: calc(100dvh - 1rem);
      overflow: hidden;
    }

    #createReservationModal #createReservationForm {
      display: flex;
      flex-direction: column;
      max-height: calc(100dvh - 1rem);
      min-height: 0;
    }

    #createReservationModal .modal-header,
    #createReservationModal .modal-footer {
      flex-shrink: 0;
    }

    #createReservationModal .modal-body {
      overflow-y: auto;
      min-height: 0;
    }

    #createReservationModal .soft-card.position-sticky {
      top: 0;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">Peludópolis</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
          <a class="nav-link" href="/me">Perfil</a>
          <a class="nav-link" href="/servicios">Servicios</a>
          <button id="logoutButton" type="button" class="btn btn-sm btn-outline-light ms-lg-2">Cerrar sesión</button>
        </div>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section class="page-header mb-4">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
          <p class="text-uppercase text-muted fw-bold small mb-1">Panel del cliente</p>
          <h1 class="mb-2">Mis reservaciones</h1>
          <p class="mb-0 text-muted">Consulta tu historial, crea nuevas reservaciones, cancela estancias válidas y registra pagos simulados.</p>
        </div>
        <div class="text-lg-end">
          <button id="newReservationButton" class="btn btn-peludo" type="button">
            <i class="bi bi-plus-circle me-1"></i>
            Nueva reservación
          </button>
          <div class="small text-muted mt-2">Selecciona mascota, habitación, fechas y servicios.</div>
        </div>
      </div>
    </section>

    <div id="pageAlert" class="alert d-none" role="alert"></div>

    <section class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="muted-label">Reservaciones</div>
          <div id="totalReservations" class="value">0</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="muted-label">Activas</div>
          <div id="activeReservations" class="value">0</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="muted-label">Pagadas</div>
          <div id="paidReservations" class="value">0</div>
        </div>
      </div>
    </section>

    <section class="soft-card mb-4">
      <div class="card-body p-3 p-lg-4">
        <div class="row g-3 align-items-end">
          <div class="col-md-6">
            <label for="searchInput" class="form-label">Buscar</label>
            <input id="searchInput" type="search" class="form-control" placeholder="Habitación, estado, fecha...">
          </div>
          <div class="col-md-4">
            <label for="statusFilter" class="form-label">Estado</label>
            <select id="statusFilter" class="form-select">
              <option value="all">Todos</option>
              <option value="pendiente">Pendiente</option>
              <option value="confirmada">Confirmada</option>
              <option value="en_curso">En curso</option>
              <option value="finalizada">Finalizada</option>
              <option value="cancelada">Cancelada</option>
            </select>
          </div>
          <div class="col-md-2 d-grid">
            <button id="refreshButton" type="button" class="btn btn-peludo">
              <i class="bi bi-arrow-clockwise me-1"></i>
              Recargar
            </button>
          </div>
        </div>
      </div>
    </section>

    <section id="reservationsContainer">
      <div class="loading-shell">
        <div class="text-center">
          <div class="spinner-border" role="status"></div>
          <p class="mt-3 text-muted">Cargando reservaciones...</p>
        </div>
      </div>
    </section>
  </main>

  <div class="modal fade" id="createReservationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <form id="createReservationForm">
          <div class="modal-header">
            <h5 class="modal-title">Nueva reservación</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body">
            <div id="createReservationAlert" class="alert d-none" role="alert"></div>

            <div class="row g-4">
              <div class="col-lg-7">
                <div class="detail-section">
                  <h5 class="mb-3">1. Habitación</h5>
                  <select id="reservationRoom" class="form-select" required>
                    <option value="">Cargando habitaciones...</option>
                  </select>
                  <div id="selectedRoomSummary" class="mt-3 text-muted small">Selecciona una habitación.</div>
                </div>

                <div class="detail-section">
                  <h5 class="mb-3">2. Mascota(s)</h5>
                  <div id="petsContainer" class="row g-2">
                    <div class="text-muted">Cargando mascotas...</div>
                  </div>
                  <div class="form-text mt-2">Solo puedes reservar mascotas registradas en tu cuenta.</div>
                </div>

                <div class="detail-section">
                  <h5 class="mb-3">3. Fechas</h5>
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label for="startDate" class="form-label">Fecha de entrada</label>
                      <input id="startDate" type="date" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                      <label for="endDate" class="form-label">Fecha de salida</label>
                      <input id="endDate" type="date" class="form-control" required>
                    </div>
                  </div>
                </div>

                <div class="detail-section">
                  <h5 class="mb-3">4. Servicios adicionales</h5>
                  <div id="servicesContainer" class="vstack gap-2">
                    <div class="text-muted">Cargando servicios...</div>
                  </div>
                </div>

                <div class="detail-section mb-0">
                  <h5 class="mb-3">5. Observaciones</h5>
                  <textarea id="reservationNotes" class="form-control" rows="3" placeholder="Medicamentos, cuidados especiales, horarios, comportamiento..."></textarea>
                </div>
              </div>

              <div class="col-lg-5">
                <div class="soft-card p-4 position-sticky" style="top: 20px;">
                  <h5>Resumen</h5>
                  <div class="border-top pt-3 mt-3">
                    <div class="d-flex justify-content-between mb-2">
                      <span>Noches</span>
                      <strong id="summaryNights">0</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Habitación</span>
                      <strong id="summaryRoomTotal">$0.00</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                      <span>Servicios</span>
                      <strong id="summaryServicesTotal">$0.00</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                      <span class="fs-5 fw-bold">Total estimado</span>
                      <strong id="summaryTotal" class="amount fs-4">$0.00</strong>
                    </div>
                    <p class="text-muted small mt-3 mb-0">El backend recalcula el total final al crear la reservación.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button id="submitReservationButton" type="submit" class="btn btn-peludo">Crear reservación</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="modal fade" id="reservationDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Detalle de reservación</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div id="reservationDetailBody" class="modal-body">
          <div class="text-center py-4">
            <div class="spinner-border" role="status"></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="paymentForm">
          <div class="modal-header">
            <h5 class="modal-title">Registrar pago</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" id="paymentReservationId">

            <div id="paymentAlert" class="alert d-none" role="alert"></div>

            <div class="detail-section mb-3">
              <div class="muted-label">Reservación</div>
              <div id="paymentReservationTitle" class="fw-bold">—</div>
              <div class="muted-label mt-2">Monto a pagar</div>
              <div id="paymentAmount" class="amount fs-4">$0.00</div>
            </div>

            <div class="mb-3">
              <label for="paymentMethod" class="form-label">Método de pago</label>
              <select id="paymentMethod" class="form-select" required>
                <option value="tarjeta">Tarjeta</option>
                <option value="transferencia">Transferencia</option>
                <option value="efectivo">Efectivo</option>
              </select>
            </div>

            <div class="mb-3">
              <label for="transactionReference" class="form-label">Referencia</label>
              <input id="transactionReference" type="text" class="form-control" placeholder="SIM-123456">
              <div class="form-text">Para el proyecto escolar usamos pago simulado.</div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button id="submitPaymentButton" type="submit" class="btn btn-peludo">Confirmar pago</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const API_BASE_URL = window.location.port === "3000" ? window.location.origin : "http://localhost:3000";
    const TOKEN_KEY = "peludopolis_token";
    const USER_KEY = "peludopolis_user";
    const SELECTED_ROOM_KEY = "peludopolis_selected_room";

    let reservations = [];
    let payments = [];
    let rooms = [];
    let pets = [];
    let services = [];
    let catalogsLoaded = false;

    let detailModal;
    let paymentModal;
    let createReservationModal;

    const formatMoney = (value) => {
      const number = Number(value || 0);
      return number.toLocaleString("es-MX", { style: "currency", currency: "MXN" });
    };

    const formatDate = (value) => {
      if (!value) return "—";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return String(value);
      return date.toLocaleDateString("es-MX", { year: "numeric", month: "short", day: "2-digit" });
    };

    const normalizeStatus = (status) => String(status || "pendiente").toLowerCase();
    const getToken = () => localStorage.getItem(TOKEN_KEY);

    const getStoredUser = () => {
      try {
        return JSON.parse(localStorage.getItem(USER_KEY) || "null");
      } catch {
        return null;
      }
    };

    const getQueryRoomId = () => {
      const params = new URLSearchParams(window.location.search);
      const raw = params.get("roomId");
      return raw ? Number(raw) : null;
    };

    const getPreselectedRoomId = () => {
      const queryRoomId = getQueryRoomId();
      if (queryRoomId) return queryRoomId;

      try {
        const stored = JSON.parse(localStorage.getItem(SELECTED_ROOM_KEY) || "null");
        return stored?.id ? Number(stored.id) : null;
      } catch {
        return null;
      }
    };

    const showPageAlert = (message, type = "danger") => {
      const alert = document.getElementById("pageAlert");
      alert.className = `alert alert-${type}`;
      alert.textContent = message;
    };

    const clearPageAlert = () => {
      const alert = document.getElementById("pageAlert");
      alert.className = "alert d-none";
      alert.textContent = "";
    };

    const showPaymentAlert = (message, type = "danger") => {
      const alert = document.getElementById("paymentAlert");
      alert.className = `alert alert-${type}`;
      alert.textContent = message;
    };

    const clearPaymentAlert = () => {
      const alert = document.getElementById("paymentAlert");
      alert.className = "alert d-none";
      alert.textContent = "";
    };

    const showCreateAlert = (message, type = "danger") => {
      const alert = document.getElementById("createReservationAlert");
      alert.className = `alert alert-${type}`;
      alert.textContent = message;
    };

    const clearCreateAlert = () => {
      const alert = document.getElementById("createReservationAlert");
      alert.className = "alert d-none";
      alert.textContent = "";
    };

    const apiRequest = async (path, options = {}) => {
      const token = getToken();
      if (!token) {
        window.location.href = "/";
        throw new Error("Debes iniciar sesión.");
      }

      const headers = {
        "Content-Type": "application/json",
        ...(options.headers || {}),
        Authorization: `Bearer ${token}`
      };

      const response = await fetch(`${API_BASE_URL}${path}`, { ...options, headers });
      const contentType = response.headers.get("content-type") || "";
      const body = contentType.includes("application/json") ? await response.json() : null;

      if (!response.ok || body?.ok === false) {
        throw new Error(body?.message || `Error HTTP ${response.status}`);
      }

      return body;
    };

    const publicApiRequest = async (path) => {
      const response = await fetch(`${API_BASE_URL}${path}`);
      const contentType = response.headers.get("content-type") || "";
      const body = contentType.includes("application/json") ? await response.json() : null;

      if (!response.ok || body?.ok === false) {
        throw new Error(body?.message || `Error HTTP ${response.status}`);
      }

      return body;
    };

    const logout = () => {
      localStorage.removeItem(TOKEN_KEY);
      localStorage.removeItem(USER_KEY);
      window.location.href = "/";
    };

    const getArrayData = (payload) => Array.isArray(payload?.data) ? payload.data : Array.isArray(payload) ? payload : [];
    const getObjectData = (payload) => payload?.data || payload || null;

    const normalizeRoom = (room) => ({
      id: Number(room.id || room.room_id),
      name: room.name || room.room_name || room.nombre_habitacion || "Habitación",
      petType: room.pet_type_allowed || room.tipo_mascota_permitida || room.type || "",
      size: room.size_allowed || room.tamaño_permitido || room.tamano_permitido || room.size || "",
      price: Number(room.price_per_night || room.precio_noche || room.price || 0),
      description: room.description || room.descripcion || "Sin descripción disponible.",
      status: room.status || room.estado || "disponible",
      capacity: Number(room.capacity || room.capacidad || 1),
      imageUrl: room.image_url || room.imagen_url || room.imageUrl || "/assets/Habitaciones.jpg"
    });

    const normalizePet = (pet) => ({
      id: Number(pet.id || pet.pet_id),
      name: pet.name || pet.pet_name || pet.nombre_mascota || "Mascota",
      species: pet.species || pet.especie || "",
      size: pet.size || pet.tamaño || pet.tamano || "",
      breed: pet.breed || pet.raza || ""
    });

    const normalizeService = (service) => ({
      id: Number(service.id || service.service_id),
      name: service.name || service.service_name || service.nombre_servicio || "Servicio",
      description: service.description || service.descripcion || "",
      price: Number(service.price || service.precio || 0),
      type: service.service_type || service.tipo_servicio || service.type || ""
    });

    const reservationHasPaidPayment = (reservationId) => {
      return payments.some((payment) => {
        const paymentReservationId = Number(payment.reservation_id || payment.reservationId);
        const status = String(payment.payment_status || payment.paymentStatus || "").toLowerCase();
        return paymentReservationId === Number(reservationId) && status === "pagado";
      });
    };

    const isPayable = (reservation) => {
      const status = normalizeStatus(reservation.reservation_status || reservation.status);
      return ["pendiente", "confirmada"].includes(status) && !reservationHasPaidPayment(reservation.id);
    };

    const isCancelable = (reservation) => {
      const status = normalizeStatus(reservation.reservation_status || reservation.status);
      return ["pendiente", "confirmada"].includes(status);
    };

    const statusBadge = (status) => {
      const normalized = normalizeStatus(status);
      return `<span class="badge-status badge-${normalized}">${normalized.replace("_", " ")}</span>`;
    };

    const paymentBadge = (reservation) => {
      if (reservationHasPaidPayment(reservation.id)) {
        return `<span class="badge-status badge-pagado">pagado</span>`;
      }
      return `<span class="badge-status badge-sin_pago">sin pago</span>`;
    };

    const getReservationSearchText = (reservation) => [
      reservation.id,
      reservation.room_name,
      reservation.roomName,
      reservation.reservation_status,
      reservation.status,
      reservation.start_date,
      reservation.end_date,
      reservation.notes
    ].filter(Boolean).join(" ").toLowerCase();

    const getFilteredReservations = () => {
      const search = document.getElementById("searchInput").value.trim().toLowerCase();
      const status = document.getElementById("statusFilter").value;

      return reservations.filter((reservation) => {
        const reservationStatus = normalizeStatus(reservation.reservation_status || reservation.status);
        const matchesStatus = status === "all" || reservationStatus === status;
        const matchesSearch = !search || getReservationSearchText(reservation).includes(search);
        return matchesStatus && matchesSearch;
      });
    };

    const updateStats = () => {
      const activeStatuses = new Set(["pendiente", "confirmada", "en_curso"]);
      const activeCount = reservations.filter((r) => activeStatuses.has(normalizeStatus(r.reservation_status || r.status))).length;
      const paidCount = reservations.filter((r) => reservationHasPaidPayment(r.id)).length;

      document.getElementById("totalReservations").textContent = reservations.length;
      document.getElementById("activeReservations").textContent = activeCount;
      document.getElementById("paidReservations").textContent = paidCount;
    };

    const renderReservations = () => {
      updateStats();
      const container = document.getElementById("reservationsContainer");
      const filtered = getFilteredReservations();

      if (!filtered.length) {
        container.innerHTML = `
          <div class="empty-state p-5 text-center">
            <i class="bi bi-calendar2-x fs-1 text-muted"></i>
            <h3 class="mt-3">No hay reservaciones para mostrar</h3>
            <p class="text-muted mb-3">Cuando tengas reservaciones reales, aparecerán aquí con su estado y opciones de pago.</p>
            <button type="button" class="btn btn-peludo" onclick="openCreateReservationModal()">
              <i class="bi bi-plus-circle me-1"></i>Nueva reservación
            </button>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="row g-3">
          ${filtered.map((reservation) => {
            const status = reservation.reservation_status || reservation.status;
            const roomName = reservation.room_name || reservation.roomName || `Habitación #${reservation.room_id || reservation.roomId || "—"}`;
            const total = reservation.total || reservation.reservation_total || 0;
            const canPay = isPayable(reservation);
            const canCancel = isCancelable(reservation);

            return `
              <div class="col-12">
                <article class="reservation-card">
                  <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                    <div>
                      <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <h4 class="mb-0">${roomName}</h4>
                        ${statusBadge(status)}
                        ${paymentBadge(reservation)}
                      </div>
                      <div class="text-muted mb-2">Reservación #${reservation.id}</div>
                      <div class="row g-3">
                        <div class="col-sm-auto">
                          <div class="muted-label">Entrada</div>
                          <div class="fw-semibold">${formatDate(reservation.start_date || reservation.startDate)}</div>
                        </div>
                        <div class="col-sm-auto">
                          <div class="muted-label">Salida</div>
                          <div class="fw-semibold">${formatDate(reservation.end_date || reservation.endDate)}</div>
                        </div>
                        <div class="col-sm-auto">
                          <div class="muted-label">Total</div>
                          <div class="amount">${formatMoney(total)}</div>
                        </div>
                      </div>
                    </div>
                    <div class="d-flex flex-wrap align-content-start gap-2 justify-content-lg-end">
                      <button type="button" class="btn btn-outline-secondary" onclick="openReservationDetail(${reservation.id})">
                        <i class="bi bi-eye me-1"></i>Detalle
                      </button>
                      <button type="button" class="btn btn-peludo" onclick="openPaymentModal(${reservation.id})" ${canPay ? "" : "disabled"}>
                        <i class="bi bi-credit-card me-1"></i>Pagar
                      </button>
                      <button type="button" class="btn btn-outline-danger" onclick="cancelReservation(${reservation.id})" ${canCancel ? "" : "disabled"}>
                        <i class="bi bi-x-circle me-1"></i>Cancelar
                      </button>
                    </div>
                  </div>
                </article>
              </div>
            `;
          }).join("")}
        </div>
      `;
    };

    const loadReservations = async () => {
      clearPageAlert();
      const container = document.getElementById("reservationsContainer");
      container.innerHTML = `
        <div class="loading-shell">
          <div class="text-center">
            <div class="spinner-border" role="status"></div>
            <p class="mt-3 text-muted">Cargando reservaciones...</p>
          </div>
        </div>
      `;

      try {
        const [reservationsBody, paymentsResult] = await Promise.allSettled([
          apiRequest("/reservations/me"),
          apiRequest("/payments/me")
        ]);

        if (reservationsBody.status === "rejected") {
          throw reservationsBody.reason;
        }

        reservations = getArrayData(reservationsBody.value);
        payments = paymentsResult.status === "fulfilled" ? getArrayData(paymentsResult.value) : [];

        if (paymentsResult.status === "rejected") {
          showPageAlert("Reservaciones cargadas, pero no se pudieron cargar pagos. Revisa que /payments/me exista.", "warning");
        }

        renderReservations();
      } catch (error) {
        container.innerHTML = `
          <div class="alert alert-danger">
            <h5 class="alert-heading">No se pudieron cargar las reservaciones</h5>
            <p class="mb-0">${error.message}</p>
          </div>
        `;
      }
    };

    const loadCatalogs = async () => {
      if (catalogsLoaded) return;
      clearCreateAlert();

      try {
        const [petsPayload, roomsPayload, servicesPayload] = await Promise.all([
          apiRequest("/pets"),
          publicApiRequest("/rooms"),
          publicApiRequest("/services")
        ]);

        pets = getArrayData(petsPayload).map(normalizePet).filter((pet) => pet.id);
        rooms = getArrayData(roomsPayload).map(normalizeRoom).filter((room) => room.id);
        services = getArrayData(servicesPayload).map(normalizeService).filter((service) => service.id);

        renderCreateFormCatalogs();
        catalogsLoaded = true;
      } catch (error) {
        showCreateAlert(`${error.message}. Revisa que existan /pets, /rooms y /services.`, "danger");
      }
    };

    const renderCreateFormCatalogs = () => {
      const roomSelect = document.getElementById("reservationRoom");
      const preselectedRoomId = getPreselectedRoomId();

      roomSelect.innerHTML = `
        <option value="">Selecciona una habitación</option>
        ${rooms.map((room) => `
          <option value="${room.id}">${room.name} · ${room.petType || "N/A"} · ${room.size || "N/A"} · ${formatMoney(room.price)}/noche</option>
        `).join("")}
      `;

      if (preselectedRoomId && rooms.some((room) => room.id === preselectedRoomId)) {
        roomSelect.value = String(preselectedRoomId);
      }

      const petsContainer = document.getElementById("petsContainer");
      if (!pets.length) {
        petsContainer.innerHTML = `
          <div class="col-12">
            <div class="alert alert-warning mb-0">
              No tienes mascotas registradas. Primero registra una en <a href="/pets">Mis Mascotas</a>.
            </div>
          </div>
        `;
      } else {
        petsContainer.innerHTML = pets.map((pet) => `
          <div class="col-md-6">
            <label class="pet-option-card d-block h-100">
              <div class="form-check">
                <input class="form-check-input pet-checkbox" type="checkbox" value="${pet.id}">
                <span class="form-check-label fw-bold">${pet.name}</span>
              </div>
              <div class="small text-muted mt-1">${pet.species || "—"} · ${pet.size || "—"}${pet.breed ? ` · ${pet.breed}` : ""}</div>
            </label>
          </div>
        `).join("");
      }

      const servicesContainer = document.getElementById("servicesContainer");
      if (!services.length) {
        servicesContainer.innerHTML = `<p class="text-muted mb-0">No hay servicios adicionales activos.</p>`;
      } else {
        servicesContainer.innerHTML = services.map((service) => `
          <div class="service-row">
            <div class="row g-2 align-items-center">
              <div class="col-md-7">
                <div class="form-check">
                  <input class="form-check-input service-checkbox" type="checkbox" value="${service.id}" id="service-${service.id}">
                  <label class="form-check-label fw-bold" for="service-${service.id}">${service.name}</label>
                </div>
                <div class="small text-muted">${service.description || service.type || "Servicio adicional"}</div>
              </div>
              <div class="col-md-3 text-md-end">
                <strong>${formatMoney(service.price)}</strong>
              </div>
              <div class="col-md-2">
                <input type="number" min="1" value="1" class="form-control service-quantity" data-service-id="${service.id}" disabled>
              </div>
            </div>
          </div>
        `).join("");
      }

      bindCreateFormEvents();
      updateSelectedRoomSummary();
      updateReservationEstimate();
    };

    const bindCreateFormEvents = () => {
      document.querySelectorAll(".service-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", () => {
          const quantity = document.querySelector(`.service-quantity[data-service-id="${checkbox.value}"]`);
          if (quantity) quantity.disabled = !checkbox.checked;
          updateReservationEstimate();
        });
      });

      document.querySelectorAll(".service-quantity").forEach((input) => {
        input.addEventListener("input", updateReservationEstimate);
      });

      document.querySelectorAll(".pet-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", updateReservationEstimate);
      });
    };

    const getSelectedRoom = () => {
      const roomId = Number(document.getElementById("reservationRoom").value || 0);
      return rooms.find((room) => room.id === roomId) || null;
    };

    const getSelectedPetIds = () => {
      return Array.from(document.querySelectorAll(".pet-checkbox:checked")).map((input) => Number(input.value));
    };

    const getSelectedServices = () => {
      return Array.from(document.querySelectorAll(".service-checkbox:checked")).map((checkbox) => {
        const quantityInput = document.querySelector(`.service-quantity[data-service-id="${checkbox.value}"]`);
        return {
          serviceId: Number(checkbox.value),
          quantity: Math.max(1, Number(quantityInput?.value || 1))
        };
      });
    };

    const calculateNights = () => {
      const startDate = document.getElementById("startDate").value;
      const endDate = document.getElementById("endDate").value;
      if (!startDate || !endDate) return 0;

      const start = new Date(`${startDate}T00:00:00`);
      const end = new Date(`${endDate}T00:00:00`);
      const diff = end.getTime() - start.getTime();
      return Math.max(0, Math.round(diff / 86400000));
    };

    const updateSelectedRoomSummary = () => {
      const room = getSelectedRoom();
      const summary = document.getElementById("selectedRoomSummary");

      if (!room) {
        summary.textContent = "Selecciona una habitación.";
        return;
      }

      summary.innerHTML = `
        <div class="room-option-card">
          <div class="fw-bold">${room.name}</div>
          <div class="small text-muted">${room.description}</div>
          <div class="d-flex flex-wrap gap-2 mt-2">
            <span class="badge bg-light text-dark border">${room.petType || "N/A"}</span>
            <span class="badge bg-light text-dark border">${room.size || "N/A"}</span>
            <span class="badge bg-light text-dark border">Capacidad ${room.capacity}</span>
            <span class="badge bg-light text-dark border">${formatMoney(room.price)}/noche</span>
          </div>
        </div>
      `;
    };

    const updateReservationEstimate = () => {
      const room = getSelectedRoom();
      const nights = calculateNights();
      const roomTotal = room ? room.price * nights : 0;
      const selectedServices = getSelectedServices();
      const servicesTotal = selectedServices.reduce((total, item) => {
        const service = services.find((entry) => entry.id === item.serviceId);
        return total + (service ? service.price * item.quantity : 0);
      }, 0);

      document.getElementById("summaryNights").textContent = nights;
      document.getElementById("summaryRoomTotal").textContent = formatMoney(roomTotal);
      document.getElementById("summaryServicesTotal").textContent = formatMoney(servicesTotal);
      document.getElementById("summaryTotal").textContent = formatMoney(roomTotal + servicesTotal);
      updateSelectedRoomSummary();
    };

    const openCreateReservationModal = async () => {
      clearCreateAlert();
      document.getElementById("createReservationForm").reset();
      document.getElementById("summaryNights").textContent = "0";
      document.getElementById("summaryRoomTotal").textContent = formatMoney(0);
      document.getElementById("summaryServicesTotal").textContent = formatMoney(0);
      document.getElementById("summaryTotal").textContent = formatMoney(0);

      createReservationModal.show();
      await loadCatalogs();

      const preselectedRoomId = getPreselectedRoomId();
      if (preselectedRoomId) {
        document.getElementById("reservationRoom").value = String(preselectedRoomId);
        updateReservationEstimate();
      }
    };

    const submitReservation = async (event) => {
      event.preventDefault();
      clearCreateAlert();

      const roomId = Number(document.getElementById("reservationRoom").value || 0);
      const petIds = getSelectedPetIds();
      const startDate = document.getElementById("startDate").value;
      const endDate = document.getElementById("endDate").value;
      const servicesPayload = getSelectedServices();
      const notes = document.getElementById("reservationNotes").value.trim();

      if (!roomId) {
        showCreateAlert("Selecciona una habitación.");
        return;
      }

      if (!petIds.length) {
        showCreateAlert("Selecciona al menos una mascota.");
        return;
      }

      if (!startDate || !endDate || calculateNights() <= 0) {
        showCreateAlert("La fecha de salida debe ser posterior a la fecha de entrada.");
        return;
      }

      const button = document.getElementById("submitReservationButton");
      const originalText = button.textContent;
      button.disabled = true;
      button.textContent = "Creando...";

      try {
        const payload = {
          roomId,
          petIds,
          startDate,
          endDate,
          services: servicesPayload,
          notes
        };

        await apiRequest("/reservations", {
          method: "POST",
          body: JSON.stringify(payload)
        });

        localStorage.removeItem(SELECTED_ROOM_KEY);
        showCreateAlert("Reservación creada correctamente.", "success");

        setTimeout(async () => {
          createReservationModal.hide();
          await loadReservations();
          const url = new URL(window.location.href);
          url.searchParams.delete("roomId");
          window.history.replaceState({}, "", url.toString());
        }, 800);
      } catch (error) {
        showCreateAlert(error.message);
      } finally {
        button.disabled = false;
        button.textContent = originalText;
      }
    };

    const renderList = (items, mapper, emptyText) => {
      if (!Array.isArray(items) || !items.length) {
        return `<p class="text-muted mb-0">${emptyText}</p>`;
      }

      return `<ul class="list-group list-group-flush">${items.map(mapper).join("")}</ul>`;
    };

    const openReservationDetail = async (reservationId) => {
      const body = document.getElementById("reservationDetailBody");
      detailModal.show();
      body.innerHTML = `<div class="text-center py-4"><div class="spinner-border" role="status"></div></div>`;

      try {
        const response = await apiRequest(`/reservations/${reservationId}`);
        const reservation = getObjectData(response);
        const status = reservation.reservation_status || reservation.status;
        const roomName = reservation.room_name || reservation.roomName || `Habitación #${reservation.room_id || reservation.roomId || "—"}`;

        body.innerHTML = `
          <div class="detail-section">
            <div class="d-flex flex-wrap justify-content-between gap-2 mb-3">
              <div>
                <div class="muted-label">Reservación #${reservation.id}</div>
                <h4 class="mb-0">${roomName}</h4>
              </div>
              <div class="d-flex flex-wrap gap-2 align-items-start">
                ${statusBadge(status)}
                ${Array.isArray(reservation.payments) && reservation.payments.some(p => String(p.payment_status).toLowerCase() === "pagado") ? `<span class="badge-status badge-pagado">pagado</span>` : paymentBadge(reservation)}
              </div>
            </div>
            <div class="row g-3">
              <div class="col-md-4">
                <div class="muted-label">Entrada</div>
                <div class="fw-semibold">${formatDate(reservation.start_date || reservation.startDate)}</div>
              </div>
              <div class="col-md-4">
                <div class="muted-label">Salida</div>
                <div class="fw-semibold">${formatDate(reservation.end_date || reservation.endDate)}</div>
              </div>
              <div class="col-md-4">
                <div class="muted-label">Total</div>
                <div class="amount fs-5">${formatMoney(reservation.total)}</div>
              </div>
            </div>
            ${reservation.notes ? `<hr><div class="muted-label">Observaciones</div><p class="mb-0">${reservation.notes}</p>` : ""}
          </div>

          <div class="detail-section">
            <h5>Mascotas</h5>
            ${renderList(reservation.pets, (pet) => `
              <li class="list-group-item px-0 d-flex justify-content-between">
                <span>${pet.name || `Mascota #${pet.id}`}</span>
                <span class="text-muted">${pet.species || "—"} · ${pet.size || "—"}</span>
              </li>
            `, "No hay mascotas asociadas.")}
          </div>

          <div class="detail-section">
            <h5>Servicios</h5>
            ${renderList(reservation.services, (service) => `
              <li class="list-group-item px-0 d-flex justify-content-between gap-3">
                <span>${service.service_name || service.name || `Servicio #${service.service_id || service.id}`}</span>
                <span class="text-muted">${service.quantity || 1} × ${formatMoney(service.unit_price || service.price || 0)} = ${formatMoney(service.subtotal || 0)}</span>
              </li>
            `, "No se agregaron servicios.")}
          </div>

          <div class="detail-section">
            <h5>Pagos</h5>
            ${renderList(reservation.payments, (payment) => `
              <li class="list-group-item px-0 d-flex justify-content-between gap-3">
                <span>${payment.payment_method || "método"} · ${payment.transaction_reference || "sin referencia"}</span>
                <span class="text-muted">${formatMoney(payment.amount)} · ${payment.payment_status || "—"}</span>
              </li>
            `, "Esta reservación aún no tiene pagos.")}
          </div>
        `;
      } catch (error) {
        body.innerHTML = `<div class="alert alert-danger mb-0">${error.message}</div>`;
      }
    };

    const cancelReservation = async (reservationId) => {
      const reservation = reservations.find((item) => Number(item.id) === Number(reservationId));
      const roomName = reservation?.room_name || reservation?.roomName || `reservación #${reservationId}`;

      if (!confirm(`¿Seguro que quieres cancelar ${roomName}?`)) return;

      try {
        await apiRequest(`/reservations/${reservationId}/cancel`, { method: "PATCH" });
        showPageAlert("Reservación cancelada correctamente.", "success");
        await loadReservations();
      } catch (error) {
        showPageAlert(error.message);
      }
    };

    const openPaymentModal = (reservationId) => {
      const reservation = reservations.find((item) => Number(item.id) === Number(reservationId));
      if (!reservation) return;

      clearPaymentAlert();
      document.getElementById("paymentReservationId").value = reservation.id;
      document.getElementById("paymentReservationTitle").textContent = reservation.room_name || reservation.roomName || `Reservación #${reservation.id}`;
      document.getElementById("paymentAmount").textContent = formatMoney(reservation.total || reservation.reservation_total || 0);
      document.getElementById("paymentMethod").value = "tarjeta";
      document.getElementById("transactionReference").value = `SIM-${Date.now().toString().slice(-6)}`;
      paymentModal.show();
    };

    const submitPayment = async (event) => {
      event.preventDefault();
      clearPaymentAlert();

      const button = document.getElementById("submitPaymentButton");
      const originalText = button.textContent;
      button.disabled = true;
      button.textContent = "Procesando...";

      try {
        const reservationId = Number(document.getElementById("paymentReservationId").value);
        const payload = {
          reservationId,
          paymentMethod: document.getElementById("paymentMethod").value,
          transactionReference: document.getElementById("transactionReference").value.trim() || `SIM-${Date.now()}`
        };

        await apiRequest("/payments", {
          method: "POST",
          body: JSON.stringify(payload)
        });

        showPaymentAlert("Pago registrado correctamente.", "success");
        setTimeout(async () => {
          paymentModal.hide();
          await loadReservations();
        }, 700);
      } catch (error) {
        showPaymentAlert(error.message);
      } finally {
        button.disabled = false;
        button.textContent = originalText;
      }
    };

    document.addEventListener("DOMContentLoaded", async () => {
      if (!getToken()) {
        window.location.href = "/";
        return;
      }

      const user = getStoredUser();
      if (!user) {
        localStorage.removeItem(TOKEN_KEY);
        window.location.href = "/";
        return;
      }

      detailModal = new bootstrap.Modal(document.getElementById("reservationDetailModal"));
      paymentModal = new bootstrap.Modal(document.getElementById("paymentModal"));
      createReservationModal = new bootstrap.Modal(document.getElementById("createReservationModal"));

      document.getElementById("logoutButton").addEventListener("click", logout);
      document.getElementById("refreshButton").addEventListener("click", loadReservations);
      document.getElementById("searchInput").addEventListener("input", renderReservations);
      document.getElementById("statusFilter").addEventListener("change", renderReservations);
      document.getElementById("paymentForm").addEventListener("submit", submitPayment);
      document.getElementById("newReservationButton").addEventListener("click", openCreateReservationModal);
      document.getElementById("createReservationForm").addEventListener("submit", submitReservation);
      document.getElementById("reservationRoom").addEventListener("change", updateReservationEstimate);
      document.getElementById("startDate").addEventListener("change", updateReservationEstimate);
      document.getElementById("endDate").addEventListener("change", updateReservationEstimate);

      await loadReservations();

      if (getPreselectedRoomId()) {
        openCreateReservationModal();
      }
    });
  </script>
</body>
</html>
