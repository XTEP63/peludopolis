<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservaciones - Peludópolis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand" href="/">Peludópolis</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/profile">Perfil</a>
                <a class="nav-link" href="/pets">Mascotas</a>
                <a class="nav-link" href="/reservations">Reservaciones</a>
                <a class="nav-link" href="/" onclick="logout()">Cerrar Sesión</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1>Mis Reservaciones</h1>
                    <button class="btn btn-primary" onclick="showNewReservationModal()">Nueva Reservación</button>
                </div>

                <div id="reservations-list">
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                        <p>Cargando reservaciones...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para nueva reservación -->
    <div class="modal fade" id="newReservationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva Reservación</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="newReservationForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="checkIn" class="form-label">Fecha de entrada</label>
                                    <input type="date" class="form-control" id="checkIn" required>
                                </div>
                                <div class="mb-3">
                                    <label for="checkOut" class="form-label">Fecha de salida</label>
                                    <input type="date" class="form-control" id="checkOut" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="roomType" class="form-label">Tipo de habitación</label>
                                    <select class="form-control" id="roomType" required>
                                        <option value="">Seleccionar tipo</option>
                                        <option value="standard">Estándar</option>
                                        <option value="deluxe">Deluxe</option>
                                        <option value="suite">Suite</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="guests" class="form-label">Número de huéspedes</label>
                                    <input type="number" class="form-control" id="guests" min="1" max="4" value="1" required>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="specialRequests" class="form-label">Solicitudes especiales</label>
                            <textarea class="form-control" id="specialRequests" rows="3"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="createReservation()">Reservar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let newReservationModal;

        async function loadReservations() {
            const token = localStorage.getItem('token');
            if (!token) {
                window.location.href = '/';
                return;
            }

            try {
                // For now, show a placeholder message since reservations API is not implemented yet
                document.getElementById('reservations-list').innerHTML = `
                    <div class="alert alert-info">
                        <h4>Módulo de Reservaciones</h4>
                        <p>Esta funcionalidad está en desarrollo. Próximamente podrás gestionar tus reservaciones aquí.</p>
                        <p>Funcionalidades planificadas:</p>
                        <ul>
                            <li>Crear nuevas reservaciones</li>
                            <li>Ver lista de reservaciones activas y pasadas</li>
                            <li>Modificar reservaciones existentes</li>
                            <li>Cancelar reservaciones</li>
                            <li>Ver detalles de habitaciones disponibles</li>
                        </ul>
                    </div>
                `;
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('reservations-list').innerHTML = `
                    <div class="alert alert-danger">
                        Error al cargar las reservaciones.
                    </div>
                `;
            }
        }

        function showNewReservationModal() {
            if (!newReservationModal) {
                newReservationModal = new bootstrap.Modal(document.getElementById('newReservationModal'));
            }
            newReservationModal.show();
        }

        async function createReservation() {
            // Placeholder for creating reservation functionality
            alert('Funcionalidad de crear reservación próximamente disponible');
            if (newReservationModal) {
                newReservationModal.hide();
            }
        }

        function logout() {
            localStorage.removeItem('token');
            window.location.href = '/';
        }

        // Initialize modal and load reservations when page loads
        document.addEventListener('DOMContentLoaded', function() {
            newReservationModal = new bootstrap.Modal(document.getElementById('newReservationModal'));
            loadReservations();
        });
    </script>
</body>
</html>